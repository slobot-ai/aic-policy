# Used by the Python extension (tests, debugger) — align with ``pixi run pytest`` in ``pixi.toml``.
# PYTEST_DISABLE_PLUGIN_AUTOLOAD avoids ``launch_testing`` hijacking collection for non-launch tests.
PYTEST_DISABLE_PLUGIN_AUTOLOAD=1
PYTHONPATH=ros_ws/src/aic_policy_ros:../aic/aic_model:../aic/.pixi/envs/default/lib/python3.12/site-packages
